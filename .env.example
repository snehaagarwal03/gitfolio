# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# GitHub OAuth (configured in Firebase Console)
# No separate key needed here -- GitHub OAuth is handled via Firebase Auth provider settings

# Server-only secrets (set in Vercel environment, do NOT expose in frontend)
# GitHub Personal Access Token (optional)
# Provides higher rate limits (5,000 vs 60 requests/hour)
# Create one at: https://github.com/settings/tokens
# Required scopes: none (public-only access)
GITHUB_TOKEN=your_github_personal_access_token

# Groq API Key (required for AI-powered portfolio and resume generation)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Firebase Admin SDK service account JSON (server-only)
# Use a single-line JSON string or set via Vercel UI
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Cloudinary Configuration (required for image and file uploads)
# Cloud name and upload preset from your Cloudinary dashboard: https://console.cloudinary.com/
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset
