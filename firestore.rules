rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow anyone to read portfolios by username mapping, but only logged in users can create/update their own
    match /portfoliosByUsername/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Allow creating mapping for custom URLs
    match /portfoliosByCustomUrl/{customUrl} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Portfolios data
    match /portfolios/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Resumes data
    match /resumes/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
